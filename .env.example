# Copy to .env and fill in keys for live APIs.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en
DEEPGRAM_ENDPOINTING_MS=300
DEEPGRAM_NO_DELAY=true
DEEPGRAM_STREAM_CHUNK_MS=20

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.45
OPENAI_STREAM_INCLUDE_USAGE=true
OPENAI_REASONING_EFFORT=minimal

CARTESIA_API_KEY=
CARTESIA_MODEL_ID=sonic-2
CARTESIA_VOICE_ID=694f9389-aac1-45b6-b726-9d9369183238
CARTESIA_API_VERSION=2025-04-16
CARTESIA_TRANSPORT=websocket
CARTESIA_VOICE_SPEED=1.0
CARTESIA_MAX_BUFFER_DELAY_MS=50
CARTESIA_SAMPLE_RATE=24000
CARTESIA_OUTPUT_ENCODING=pcm_s16le
TTS_REPLACEMENT_JSON={}

SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
SILERO_VAD_THRESHOLD=0.8
SILERO_MIN_SPEECH_MS=200
SILERO_MIN_SILENCE_DURATION_MS=400
SILERO_SPEECH_PAD_MS=64

MOCK_REGISTERED_CALLER=false
MOCK_KYC_PHONE_LAST4=9876
MOCK_KYC_PAN_LAST4=1234
MOCK_KYC_DOB=1994-08-01
LOG_LEVEL=INFO
